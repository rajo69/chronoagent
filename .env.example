# Copy to .env and fill in real values. Never commit .env.

# ── Core ──────────────────────────────────────────────────────────────────────
CHRONO_ENV=dev                          # dev | prod | test

# ── LLM backend ───────────────────────────────────────────────────────────────
CHRONO_LLM_BACKEND=together             # together | mock | ollama
CHRONO_TOGETHER_API_KEY=               # Required for together backend
CHRONO_TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
CHRONO_OLLAMA_BASE_URL=http://localhost:11434
CHRONO_OLLAMA_MODEL=phi3:mini

# ── Infrastructure ────────────────────────────────────────────────────────────
CHRONO_REDIS_URL=redis://localhost:6379/0
CHRONO_DATABASE_URL=sqlite:///./chronoagent.db
CHRONO_CHROMA_PERSIST_DIR=./chroma_data

# ── Forecaster ────────────────────────────────────────────────────────────────
CHRONO_FORECASTER_ENABLED=true
CHRONO_FORECASTER_HORIZON=10
CHRONO_BOCPD_HAZARD_RATE=0.01
CHRONO_ENSEMBLE_WEIGHTS_BOCPD=0.4
CHRONO_ENSEMBLE_WEIGHTS_CHRONOS=0.6

# ── Health scoring ────────────────────────────────────────────────────────────
CHRONO_HEALTH_SCORE_WINDOW=50

# ── Escalation ────────────────────────────────────────────────────────────────
CHRONO_ESCALATION_THRESHOLD=0.3
CHRONO_ESCALATION_COOLDOWN=300
